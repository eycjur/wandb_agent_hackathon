GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_APIKEY=  # ax 用の代替（GEMINI_API_KEY が優先）

# GEPA 最適化: LLM 同時呼び出し数の上限（デフォルト: 20）。API レート制限を超えないよう調整。
# GEPA_MAX_CONCURRENT_CALLS=20

# 各 LLM 呼び出しの開始・終了をログ出力（デバッグ用）。1 で有効。
# GEPA_LLM_CALL_LOGGING=1

# W&B / Weave (optional): ログ・評価結果の保存に使用
WANDB_API_KEY=
WANDB_PROJECT=resume-assistant
# WANDB_ENTITY=your-username  # 推奨。未設定時は W&B API からデフォルト entity を取得。
#                             # 設定すると API 呼び出しを省略でき、保存・取得が安定します。
